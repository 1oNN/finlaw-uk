# --- Neo4j (used by backend/graph/client.py) ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASS=finlaw

# --- Ollama (used by backend/llm/ollama_client.py) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT=300
OLLAMA_NUM_PREDICT=640
OLLAMA_TEMPERATURE=0.25
OLLAMA_NUM_CTX=8192

# --- Retrieval / RAG (used by backend/retrieval/) ---
# Where the sparse retriever looks for static reference docs (PDFs etc.)
RAG_DATA_DIR=./backend/data
# Max chars per snippet returned to the model
RAG_MAX_SNIP=2200
# Top-k results per search backend
RAG_TOPK=3
# Enable best-effort remote legislation.gov.uk lookup as last-resort fallback
RAG_ENABLE_REMOTE=1
# Enable Neo4j graph-boost in retrieval (set to 0 to disable Neo4j queries)
RAG_ENABLE_GRAPH=1
# Verbose RAG logging
RAG_DEBUG=0

# Dense retrieval (used by backend/retrieval/dense.py) — Stage 1
DENSE_MODEL=BAAI/bge-small-en-v1.5
DENSE_CACHE_DIR=./data/cache
DENSE_TOPK=5
DENSE_DEVICE=cpu
# Disable dense retrieval entirely (orchestrator falls back to sparse-only)
RAG_ENABLE_DENSE=1
# RRF constant (smaller = more weight to top results); literature default is 60
RAG_RRF_K=60

# --- Flask (used by backend/app.py) ---
FLASK_ENV=development
PORT=5000
UPLOAD_FOLDER=./uploads
STRICT_CITATIONS=1
CITATION_PATCH_ENABLED=1

# --- Frontend auth (used by the React app's leftover stubs; no Python backend yet) ---
# DATABASE_URL=
# SECRET_KEY=
# JWT_SECRET_KEY=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Stage 4 verification (used by backend/verification/) ---
GRAPH_VERIFY_ENABLED=1
CLAIM_TRACE_ENABLED=1
CLAIM_TRACE_MAX_ITEMS=8

# --- Stage 5 evaluation (used by backend/evaluation/) ---
# Which LLM acts as the RAGAS judge. 'ollama' uses the same local Mistral
# the chat backend uses; 'hf' uses backend/llm/hf_client (downloads ~14 GB
# Mistral weights via HF transformers on first run).
RAGAS_JUDGE=ollama
# Output directory for eval result CSVs
EVAL_OUTPUT_DIR=./data/eval_results
